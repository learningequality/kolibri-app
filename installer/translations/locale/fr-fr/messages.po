msgstr "Tâches supplémentaires :"

msgctxt "[Messages]DownloadingLabel2"
msgid "Downloading files..."
msgstr "Téléchargement des fichiers..."

msgctxt "[Messages]ButtonStopDownload"
msgid "&Stop download"
msgstr "&Arrêter le téléchargement"

msgctxt "[Messages]StopDownload"
msgid "Are you sure you want to stop the download?"
msgstr "Êtes-vous sûr de vouloir arrêter le téléchargement ?"

msgctxt "[Messages]ErrorDownloadAborted"
msgid "Download aborted"
msgstr "Téléchargement annulé"

msgctxt "[Messages]ErrorDownloadFailed"
msgid "Download failed: %1 %2"
msgstr "Le téléchargement a échoué : %1 %2"

msgctxt "[Messages]ErrorDownloadSizeFailed"
msgid "Getting size failed: %1 %2"
msgstr "La récupération de la taille du fichier a échoué : %1 %2"

msgctxt "[Messages]ErrorProgress"
msgid "Invalid progress: %1 of %2"
msgstr "Progression invalide : %1 sur %2"

msgctxt "[Messages]ErrorFileSize"
msgid "Invalid file size: expected %1, found %2"
msgstr "Taille du fichier invalide : attendue %1, trouvée %2"

msgctxt "[Messages]ExtractingLabel"
msgid "Extracting files..."
msgstr "Extraction des fichiers..."

msgctxt "[Messages]ButtonStopExtraction"
msgid "&Stop extraction"
msgstr "&Arrêter l'extraction"

msgctxt "[Messages]StopExtraction"
msgid "Are you sure you want to stop the extraction?"
msgstr "Êtes-vous sûr de vouloir arrêter l'extraction ?"

msgctxt "[Messages]ErrorExtractionAborted"
msgid "Extraction aborted"
msgstr "Extraction annulée"

msgctxt "[Messages]ErrorExtractionFailed"
msgid "Extraction failed: %1"
msgstr "L'extraction a échoué : %1"

msgctxt "[Messages]ArchiveIncorrectPassword"
msgid "The password is incorrect"
