msgstr "A seleção atual requer pelo menos [gb] GB de espaço em disco."

msgctxt "[Messages]ComponentsDiskSpaceMBLabel"
msgid "Current selection requires at least [mb] MB of disk space."
msgstr "A seleção atual requer pelo menos [mb] MB de espaço em disco."

