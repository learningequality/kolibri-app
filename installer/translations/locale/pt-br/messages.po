msgid "Password"
msgstr "Senha"

msgctxt "[Messages]PasswordLabel1"
msgid "This installation is password protected."
msgstr "Esta instalação está protegida por senha."

msgctxt "[Messages]PasswordLabel3"
msgid ""
"Please provide the password, then click Next to continue. Passwords are "
"case-sensitive."
msgstr ""
"Por favor forneça a senha, então clique em Avançar pra continuar. As senhas "
"são caso-sensitivo."

