msgstr ""
"Seleziona \"Installa\" per continuare con l'installazione, o \"Indietro\" "
"per rivedere o modificare le impostazioni."

msgctxt "[Messages]ReadyLabel2b"
msgid "Click Install to continue with the installation."
msgstr "Per procedere con l'installazione seleziona \"Installa\"."

