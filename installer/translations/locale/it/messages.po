msgstr "Preparazione all'installazione"

msgctxt "[Messages]PreparingDesc"
msgid "Setup is preparing to install [name] on your computer."
msgstr "Preparazione all'installazione di [name] nel computer."

msgctxt "[Messages]PreviousInstallNotCompleted"
msgid ""
"The installation/removal of a previous program was not completed. You will "
"need to restart your computer to complete that installation.%n%nAfter "
"restarting your computer, run Setup again to complete the installation of "
"[name]."
msgstr ""
"L'installazione/rimozione precedente del programma non è stata "
"completata.%n%nPer completare l'installazione è necessario riavviare il "
"sistema.%n%nDopo il riavvio del sistema esegui di nuovo l'installazione di "
"[name]."

msgctxt "[Messages]CannotContinue"
msgid "Setup cannot continue. Please click Cancel to exit."
msgstr "L'installazione non può continuare. Seleziona \"Annulla\" per uscire."

msgctxt "[Messages]ApplicationsFound"
