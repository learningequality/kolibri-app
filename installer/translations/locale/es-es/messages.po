msgstr "Progreso no válido: %1 de %2"

msgctxt "[Messages]ErrorFileSize"
msgid "Invalid file size: expected %1, found %2"
msgstr "Tamaño de archivo no válido: esperado %1, encontrado %2"

msgctxt "[Messages]ExtractingLabel"
msgid "Extracting files..."
msgstr "Extrayendo archivos..."

msgctxt "[Messages]ButtonStopExtraction"
msgid "&Stop extraction"
msgstr "&Detener extracción"

msgctxt "[Messages]StopExtraction"
msgid "Are you sure you want to stop the extraction?"
msgstr "¿Está seguro que desea detener la extracción?"

msgctxt "[Messages]ErrorExtractionAborted"
msgid "Extraction aborted"
msgstr "Extracción cancelada"

msgctxt "[Messages]ErrorExtractionFailed"
msgid "Extraction failed: %1"
msgstr "Falló la extracción: %1"

msgctxt "[Messages]ArchiveIncorrectPassword"
msgid "The password is incorrect"
msgstr "La contraseña es incorrecta"

msgctxt "[Messages]ArchiveIsCorrupted"
msgid "The archive is corrupted"
msgstr "El archivo está dañado"

msgctxt "[Messages]ArchiveUnsupportedFormat"
msgid "The archive format is unsupported"
msgstr "El formato de archivo no está soportado"

msgctxt "[Messages]WizardPreparing"
msgid "Preparing to Install"
msgstr "Preparándose para Instalar"

msgctxt "[Messages]PreparingDesc"
msgid "Setup is preparing to install [name] on your computer."
msgstr ""
"El programa de instalación está preparándose para instalar [name] en su "
"sistema."

msgctxt "[Messages]PreviousInstallNotCompleted"
msgid ""
"The installation/removal of a previous program was not completed. You will "
"need to restart your computer to complete that installation.%n%nAfter "
"restarting your computer, run Setup again to complete the installation of "
