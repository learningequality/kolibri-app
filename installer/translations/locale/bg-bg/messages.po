msgctxt "[Messages]SetupAppTitle"
msgid "Setup"
msgstr "Инсталиране"

msgctxt "[Messages]SetupWindowTitle"
msgid "Setup - %1"
msgstr "Инсталиране на %1"

msgctxt "[Messages]UninstallAppTitle"
msgid "Uninstall"
msgstr "Деинсталиране"

msgctxt "[Messages]UninstallAppFullTitle"
msgid "%1 Uninstall"
msgstr "Деинсталиране на %1"

msgctxt "[Messages]InformationTitle"
msgid "Information"
msgstr "Информация"

msgctxt "[Messages]ConfirmTitle"
msgid "Confirm"
msgstr "Потвърждение"

msgctxt "[Messages]ErrorTitle"
msgid "Error"
msgstr "Грешка"

msgctxt "[Messages]SetupLdrStartupMessage"
msgid "This will install %1. Do you wish to continue?"
msgstr "Ще се инсталира %1. Желаете ли да продължите?"

msgctxt "[Messages]LdrCannotCreateTemp"
msgid "Unable to create a temporary file. Setup aborted"
msgstr ""
"Не е възможно да се създаде временен файл. Инсталирането бе прекратено"

msgctxt "[Messages]LdrCannotExecTemp"
msgid "Unable to execute file in the temporary directory. Setup aborted"
msgstr ""
"Не е възможно да се стартира файл от временната директория. Инсталирането бе"
" прекратено"

msgctxt "[Messages]HelpTextNote"
msgid ""
msgstr ""

msgctxt "[Messages]LastErrorMessage"
msgid "%1.%n%nError %2: %3"
msgstr "%1.%n%nГрешка %2: %3"

msgctxt "[Messages]SetupFileMissing"
msgid ""
"The file %1 is missing from the installation directory. Please correct the "
"problem or obtain a new copy of the program."
msgstr ""
"Файлът %1 липсва от инсталационната директория. Моля, отстранете проблема "
"или се снабдете с ново копие на програмата."

msgctxt "[Messages]SetupFileCorrupt"
msgid ""
"The setup files are corrupted. Please obtain a new copy of the program."
msgstr ""
"Инсталационните файлове са повредени. Моля, снабдете се с ново копие на "
"програмата."

msgctxt "[Messages]SetupFileCorruptOrWrongVer"
msgid ""
"The setup files are corrupted, or are incompatible with this version of "
"Setup. Please correct the problem or obtain a new copy of the program."
msgstr ""
"Инсталационните файлове са повредени или несъвместими с тази версия на "
"инсталатора. Моля, отстранете проблема или се снабдете с ново копие на "
"програмата."

msgctxt "[Messages]InvalidParameter"
msgid "An invalid parameter was passed on the command line:%n%n%1"
msgstr "В командния ред е подаден невалиден параметър:%n%n%1"

msgctxt "[Messages]SetupAlreadyRunning"
msgid "Setup is already running."
msgstr "Инсталаторът вече се изпълнява."

msgctxt "[Messages]WindowsVersionNotSupported"
msgid ""
"This program does not support the version of Windows your computer is "
"running."
msgstr ""
"Програмата не поддържа версията на Windows, с която работи компютърът ви."

msgctxt "[Messages]WindowsServicePackRequired"
msgid "This program requires %1 Service Pack %2 or later."
msgstr "Програмата изисква %1 Service Pack %2 или по-нов."

msgctxt "[Messages]NotOnThisPlatform"
msgid "This program will not run on %1."
msgstr "Програмата не може да се изпълнява под %1."

msgctxt "[Messages]OnlyOnThisPlatform"
msgid "This program must be run on %1."
msgstr "Програмата трябва да се изпълнява под %1."

msgctxt "[Messages]OnlyOnTheseArchitectures"
msgid ""
"This program can only be installed on versions of Windows designed for the "
"following processor architectures:%n%n%1"
msgstr ""
"Програмата може да се инсталира само под версии на Windows за следните "
"процесорни архитектури:%n%n%1"

msgctxt "[Messages]WinVersionTooLowError"
msgid "This program requires %1 version %2 or later."
msgstr "Програмата изисква %1 версия %2 или по-нова."

msgctxt "[Messages]WinVersionTooHighError"
msgid "This program cannot be installed on %1 version %2 or later."
msgstr "Програмата не може да бъде инсталирана в %1 версия %2 или по-нова."

msgctxt "[Messages]AdminPrivilegesRequired"
msgid ""
"You must be logged in as an administrator when installing this program."
msgstr "За да инсталирате програмата, трябва да влезете като администратор."

msgctxt "[Messages]PowerUserPrivilegesRequired"
msgid ""
"You must be logged in as an administrator or as a member of the Power Users "
"group when installing this program."
msgstr ""
"За да инсталирате програмата, трябва да влезете като администратор или "
"потребител с разширени права."

msgctxt "[Messages]SetupAppRunningError"
msgid ""
"Setup has detected that %1 is currently running.%n%nPlease close all "
"instances of it now, then click OK to continue, or Cancel to exit."
msgstr ""
"Инсталаторът установи, че %1 се изпълнява в момента.%n%nМоля, затворете "
"всички копия на програмата и натиснете \"OK\", за да продължите, или "
"\"Cancel\" за изход."

msgctxt "[Messages]UninstallAppRunningError"
msgid ""
"Uninstall has detected that %1 is currently running.%n%nPlease close all "
"instances of it now, then click OK to continue, or Cancel to exit."
msgstr ""
"Деинсталаторът установи, че %1 се изпълнява в момента.%n%nМоля, затворете "
"всички копия на програмата и натиснете \"OK\", за да продължите, или "
"\"Cancel\" за изход."

msgctxt "[Messages]PrivilegesRequiredOverrideTitle"
msgid "Select Setup Install Mode"
msgstr "Избор на режим на инсталация"

msgctxt "[Messages]PrivilegesRequiredOverrideInstruction"
msgid "Select install mode"
msgstr "Изберете режим на инсталация"

msgctxt "[Messages]PrivilegesRequiredOverrideText1"
msgid ""
"%1 can be installed for all users (requires administrative privileges), or "
"for you only."
msgstr ""
"%1 може да бъде инсталирана за всички потребители (изисква администраторски "
"привилегии) или само за Вас."

msgctxt "[Messages]PrivilegesRequiredOverrideText2"
msgid ""
"%1 can be installed for you only, or for all users (requires administrative "
"privileges)."
msgstr ""
"%1 може да бъде инсталирана само за Вас или за всички потребители (изисква "
"администраторски привилегии)."

msgctxt "[Messages]PrivilegesRequiredOverrideAllUsers"
msgid "Install for &all users"
msgstr "Инсталирай за &всички потребители"

msgctxt "[Messages]PrivilegesRequiredOverrideAllUsersRecommended"
msgid "Install for &all users (recommended)"
msgstr "Инсталирай за &всички потребители (препоръчва се)"

msgctxt "[Messages]PrivilegesRequiredOverrideCurrentUser"
msgid "Install for &me only"
msgstr "Инсталирай само за &мен"

msgctxt "[Messages]PrivilegesRequiredOverrideCurrentUserRecommended"
msgid "Install for &me only (recommended)"
msgstr "Инсталирай само за &мен (препоръчва се)"

msgctxt "[Messages]ErrorCreatingDir"
msgid "Setup was unable to create the directory \"%1\""
msgstr "Не е възможно да се създаде директория \"%1\""

msgctxt "[Messages]ErrorTooManyFilesInDir"
msgid ""
"Unable to create a file in the directory \"%1\" because it contains too many"
" files"
msgstr ""
"Не е възможно да се създаде файл в директорията \"%1\", тъй като тя съдържа "
"твърде много файлове"

msgctxt "[Messages]ExitSetupTitle"
msgid "Exit Setup"
msgstr "Затваряне на инсталатора"

msgctxt "[Messages]ExitSetupMessage"
msgid ""
"Setup is not complete. If you exit now, the program will not be "
"installed.%n%nYou may run Setup again at another time to complete the "
"installation.%n%nExit Setup?"
msgstr ""
"Инсталирането не е завършено. Ако затворите сега, програмата няма да бъде "
"инсталирана.%n%nПо-късно можете отново да стартирате инсталатора, за да "
"завършите инсталирането.%n%nЗатваряте ли инсталатора?"

msgctxt "[Messages]AboutSetupMenuItem"
msgid "&About Setup..."
msgstr "&За инсталатора..."

msgctxt "[Messages]AboutSetupTitle"
msgid "About Setup"
msgstr "За инсталатора"

msgctxt "[Messages]AboutSetupMessage"
msgid "%1 version %2%n%3%n%n%1 home page:%n%4"
msgstr "%1 версия %2%n%3%n%nУебстраница:%n%4"

msgctxt "[Messages]AboutSetupNote"
msgid ""
msgstr ""

msgctxt "[Messages]TranslatorNote"
msgid ""
msgstr "Превод на български: Михаил Балабанов"

msgctxt "[Messages]ButtonBack"
msgid "< &Back"
msgstr "< На&зад"

msgctxt "[Messages]ButtonNext"
msgid "&Next >"
msgstr "На&пред >"

msgctxt "[Messages]ButtonInstall"
msgid "&Install"
msgstr "&Инсталиране"

msgctxt "[Messages]ButtonOK"
msgid "OK"
msgstr "OK"

msgctxt "[Messages]ButtonCancel"
msgid "Cancel"
msgstr "Отказ"

msgctxt "[Messages]ButtonYes"
msgid "&Yes"
msgstr "&Да"

msgctxt "[Messages]ButtonYesToAll"
msgid "Yes to &All"
msgstr "Да за &всички"

msgctxt "[Messages]ButtonNo"
msgid "&No"
msgstr "&Не"

msgctxt "[Messages]ButtonNoToAll"
msgid "N&o to All"
msgstr "Не за в&сички"

msgctxt "[Messages]ButtonFinish"
msgid "&Finish"
msgstr "&Готово"

msgctxt "[Messages]ButtonBrowse"
msgid "&Browse..."
msgstr "Пре&глед..."

msgctxt "[Messages]ButtonWizardBrowse"
msgid "B&rowse..."
msgstr "Пре&глед..."

msgctxt "[Messages]ButtonNewFolder"
msgid "&Make New Folder"
msgstr "&Нова папка"

msgctxt "[Messages]SelectLanguageTitle"
msgid "Select Setup Language"
msgstr "Избор на език за инсталатора"

msgctxt "[Messages]SelectLanguageLabel"
msgid "Select the language to use during the installation."
msgstr "Изберете кой език ще ползвате с инсталатора."

msgctxt "[Messages]ClickNext"
msgid "Click Next to continue, or Cancel to exit Setup."
msgstr ""
"Натиснете \"Напред\", за да продължите, или \"Отказ\" за затваряне на "
"инсталатора."

msgctxt "[Messages]BeveledLabel"
msgid ""
msgstr ""

msgctxt "[Messages]BrowseDialogTitle"
msgid "Browse For Folder"
msgstr "Преглед за папка"

msgctxt "[Messages]BrowseDialogLabel"
msgid "Select a folder in the list below, then click OK."
msgstr "Изберете папка от долния списък и натиснете \"OK\"."

msgctxt "[Messages]NewFolderName"
msgid "New Folder"
msgstr "Нова папка"

msgctxt "[Messages]WelcomeLabel1"
msgid "Welcome to the [name] Setup Wizard"
msgstr "Добре дошли при Съветника за инсталиране на [name]"

msgctxt "[Messages]WelcomeLabel2"
msgid ""
"This will install [name/ver] on your computer.%n%nIt is recommended that you"
" close all other applications before continuing."
msgstr ""
"Съветникът ще инсталира [name/ver] във Вашия компютър.%n%nПрепоръчва се да "
"затворите всички останали приложения, преди да продължите."

msgctxt "[Messages]WizardPassword"
msgid "Password"
msgstr "Парола"

msgctxt "[Messages]PasswordLabel1"
msgid "This installation is password protected."
msgstr "Инсталацията е защитена с парола."

msgctxt "[Messages]PasswordLabel3"
msgid ""
"Please provide the password, then click Next to continue. Passwords are "
"case-sensitive."
msgstr ""
"Моля, въведете паролата и натиснете \"Напред\", за да продължите. Главни и "
"малки букви са от значение."

msgctxt "[Messages]PasswordEditLabel"
msgid "&Password:"
msgstr "&Парола:"

msgctxt "[Messages]IncorrectPassword"
msgid "The password you entered is not correct. Please try again."
msgstr "Въведената от вас парола е неправилна. Моля, опитайте отново."

msgctxt "[Messages]WizardLicense"
msgid "License Agreement"
msgstr "Лицензионно споразумение"

msgctxt "[Messages]LicenseLabel"
msgid "Please read the following important information before continuing."
msgstr "Моля, прочетете следната важна информация, преди да продължите."

msgctxt "[Messages]LicenseLabel3"
msgid ""
"Please read the following License Agreement. You must accept the terms of "
"this agreement before continuing with the installation."
msgstr ""
"Моля, прочетете следното Лицензионно споразумение. Преди инсталирането да "
"продължи, трябва да приемете условията на споразумението."

msgctxt "[Messages]LicenseAccepted"
msgid "I &accept the agreement"
msgstr "П&риемам споразумението"

msgctxt "[Messages]LicenseNotAccepted"
msgid "I &do not accept the agreement"
msgstr "&Не приемам споразумението"

msgctxt "[Messages]WizardInfoBefore"
msgid "Information"
msgstr "Информация"

msgctxt "[Messages]InfoBeforeLabel"
msgid "Please read the following important information before continuing."
msgstr "Моля, прочетете следната важна информация, преди да продължите."

msgctxt "[Messages]InfoBeforeClickLabel"
msgid "When you are ready to continue with Setup, click Next."
msgstr "Когато сте готов да продължите, натиснете \"Напред\"."

msgctxt "[Messages]WizardInfoAfter"
msgid "Information"
msgstr "Информация"

msgctxt "[Messages]InfoAfterLabel"
msgid "Please read the following important information before continuing."
msgstr "Моля, прочетете следната важна информация, преди да продължите."

msgctxt "[Messages]InfoAfterClickLabel"
msgid "When you are ready to continue with Setup, click Next."
msgstr "Когато сте готов да продължите, натиснете \"Напред\"."

msgctxt "[Messages]WizardUserInfo"
msgid "User Information"
msgstr "Данни за потребител"

msgctxt "[Messages]UserInfoDesc"
msgid "Please enter your information."
msgstr "Моля, въведете вашите данни."

msgctxt "[Messages]UserInfoName"
msgid "&User Name:"
msgstr "&Име:"

msgctxt "[Messages]UserInfoOrg"
msgid "&Organization:"
msgstr "&Организация:"

msgctxt "[Messages]UserInfoSerial"
msgid "&Serial Number:"
msgstr "&Сериен номер:"

msgctxt "[Messages]UserInfoNameRequired"
msgid "You must enter a name."
msgstr "Трябва да въведете име."

msgctxt "[Messages]WizardSelectDir"
msgid "Select Destination Location"
msgstr "Избор на местоназначение"

msgctxt "[Messages]SelectDirDesc"
msgid "Where should [name] be installed?"
msgstr "Къде да се инсталира [name]?"

msgctxt "[Messages]SelectDirLabel3"
msgid "Setup will install [name] into the following folder."
msgstr "[name] ще се инсталира в следната папка."

msgctxt "[Messages]SelectDirBrowseLabel"
msgid ""
"To continue, click Next. If you would like to select a different folder, "
"click Browse."
msgstr ""
"Натиснете \"Напред\", за да продължите. За да изберете друга папка, "
"натиснете \"Преглед\"."

msgctxt "[Messages]DiskSpaceGBLabel"
msgid "At least [gb] GB of free disk space is required."
msgstr "Изискват се поне [gb] ГБ свободно дисково пространство."

msgctxt "[Messages]DiskSpaceMBLabel"
msgid "At least [mb] MB of free disk space is required."
msgstr "Изискват се поне [mb] МБ свободно дисково пространство."

msgctxt "[Messages]CannotInstallToNetworkDrive"
msgid "Setup cannot install to a network drive."
msgstr "Инсталаторът не може да инсталира на мрежово устройство."

msgctxt "[Messages]CannotInstallToUNCPath"
msgid "Setup cannot install to a UNC path."
msgstr "Инсталаторът не може да инсталира в UNC път."

msgctxt "[Messages]InvalidPath"
msgid ""
"You must enter a full path with drive letter; for example:%n%nC:\\APP%n%nor "
"a UNC path in the form:%n%n\\\\server\\share"
msgstr ""
"Трябва да въведете пълен път с буква на устройство, "
"например:%n%nC:\\APP%n%nили UNC път във вида:%n%n\\\\сървър\\споделено място"

msgctxt "[Messages]InvalidDrive"
msgid ""
"The drive or UNC share you selected does not exist or is not accessible. "
"Please select another."
msgstr ""
"Избраното от вас устройство или споделено UNC място не съществува или не е "
"достъпно. Моля, изберете друго."

msgctxt "[Messages]DiskSpaceWarningTitle"
msgid "Not Enough Disk Space"
msgstr "Недостиг на дисково пространство"

msgctxt "[Messages]DiskSpaceWarning"
msgid ""
"Setup requires at least %1 KB of free space to install, but the selected "
"drive only has %2 KB available.%n%nDo you want to continue anyway?"
msgstr ""
"Инсталирането изисква %1 кБ свободно място, но на избраното устройство има "
"само %2 кБ.%n%nЖелаете ли все пак да продължите?"

msgctxt "[Messages]DirNameTooLong"
msgid "The folder name or path is too long."
msgstr "Твърде дълго име на папка или път."

msgctxt "[Messages]InvalidDirName"
msgid "The folder name is not valid."
msgstr "Името на папка е невалидно."

msgctxt "[Messages]BadDirName32"
msgid "Folder names cannot include any of the following characters:%n%n%1"
msgstr "Имената на папки не могат да съдържат следните знаци:%n%n%1"

msgctxt "[Messages]DirExistsTitle"
msgid "Folder Exists"
msgstr "Папката съществува"

msgctxt "[Messages]DirExists"
msgid ""
"The folder:%n%n%1%n%nalready exists. Would you like to install to that "
"folder anyway?"
msgstr ""
"Папката:%n%n%1%n%nвече съществува. Желаете ли все пак да инсталирате в нея?"

msgctxt "[Messages]DirDoesntExistTitle"
msgid "Folder Does Not Exist"
msgstr "Папката не съществува"

msgctxt "[Messages]DirDoesntExist"
msgid ""
"The folder:%n%n%1%n%ndoes not exist. Would you like the folder to be "
"created?"
msgstr "Папката:%n%n%1%n%nне съществува. Желаете ли да бъде създадена?"

msgctxt "[Messages]WizardSelectComponents"
msgid "Select Components"
msgstr "Избор на компоненти"

msgctxt "[Messages]SelectComponentsDesc"
msgid "Which components should be installed?"
msgstr "Кои компоненти да бъдат инсталирани?"

msgctxt "[Messages]SelectComponentsLabel2"
msgid ""
"Select the components you want to install; clear the components you do not "
"want to install. Click Next when you are ready to continue."
msgstr ""
"Изберете компонентите, които желаете да инсталирате, и откажете нежеланите. "
"Натиснете \"Напред\", когато сте готов да продължите."

msgctxt "[Messages]FullInstallation"
msgid "Full installation"
msgstr "Пълна инсталация"

msgctxt "[Messages]CompactInstallation"
msgid "Compact installation"
msgstr "Компактна инсталация"

msgctxt "[Messages]CustomInstallation"
msgid "Custom installation"
msgstr "Инсталация по избор"

msgctxt "[Messages]NoUninstallWarningTitle"
msgid "Components Exist"
msgstr "Компонентите съществуват"

msgctxt "[Messages]NoUninstallWarning"
msgid ""
"Setup has detected that the following components are already installed on "
"your computer:%n%n%1%n%nDeselecting these components will not uninstall "
"them.%n%nWould you like to continue anyway?"
msgstr ""
"Инсталаторът установи, че следните компоненти са вече инсталирани в "
"компютърa:%n%n%1%n%nОтказването на тези компоненти няма да ги "
"деинсталира.%n%nЖелаете ли все пак да продължите?"

msgctxt "[Messages]ComponentSize1"
msgid "%1 KB"
msgstr "%1 кБ"

msgctxt "[Messages]ComponentSize2"
msgid "%1 MB"
msgstr "%1 МБ"

msgctxt "[Messages]ComponentsDiskSpaceGBLabel"
msgid "Current selection requires at least [gb] GB of disk space."
msgstr "Направеният избор изисква поне [gb] ГБ дисково пространство."

msgctxt "[Messages]ComponentsDiskSpaceMBLabel"
msgid "Current selection requires at least [mb] MB of disk space."
msgstr "Направеният избор изисква поне [mb] МБ дисково пространство."

msgctxt "[Messages]WizardSelectTasks"
msgid "Select Additional Tasks"
msgstr "Избор на допълнителни задачи"

msgctxt "[Messages]SelectTasksDesc"
msgid "Which additional tasks should be performed?"
msgstr "Кои допълнителни задачи да бъдат изпълнени?"

msgctxt "[Messages]SelectTasksLabel2"
msgid ""
"Select the additional tasks you would like Setup to perform while installing"
" [name], then click Next."
msgstr ""
"Изберете кои допълнителни задачи желаете да се изпълнят при инсталиране на "
"[name], след което натиснете \"Напред\"."

msgctxt "[Messages]WizardSelectProgramGroup"
msgid "Select Start Menu Folder"
msgstr "Избор на папка в менюто \"Старт\""

msgctxt "[Messages]SelectStartMenuFolderDesc"
msgid "Where should Setup place the program's shortcuts?"
msgstr "Къде да бъдат поставени преките пътища на програмата?"

msgctxt "[Messages]SelectStartMenuFolderLabel3"
msgid ""
"Setup will create the program's shortcuts in the following Start Menu "
"folder."
msgstr ""
"Инсталаторът ще създаде преки пътища в следната папка от менюто \"Старт\"."

msgctxt "[Messages]SelectStartMenuFolderBrowseLabel"
msgid ""
"To continue, click Next. If you would like to select a different folder, "
"click Browse."
msgstr ""
"Натиснете \"Напред\", за да продължите. За да изберете друга папка, "
"натиснете \"Преглед\"."

msgctxt "[Messages]MustEnterGroupName"
msgid "You must enter a folder name."
msgstr "Трябва да въведете име на папка."

msgctxt "[Messages]GroupNameTooLong"
msgid "The folder name or path is too long."
msgstr "Твърде дълго име на папка или път."

msgctxt "[Messages]InvalidGroupName"
msgid "The folder name is not valid."
msgstr "Името на папка е невалидно."

msgctxt "[Messages]BadGroupName"
msgid "The folder name cannot include any of the following characters:%n%n%1"
msgstr "Името на папка не може да съдържа следните знаци:%n%n%1"

msgctxt "[Messages]NoProgramGroupCheck2"
msgid "&Don't create a Start Menu folder"
msgstr "И&нсталиране без папка в менюто \"Старт\""

msgctxt "[Messages]WizardReady"
msgid "Ready to Install"
msgstr "Готовност за инсталиране"

msgctxt "[Messages]ReadyLabel1"
msgid "Setup is now ready to begin installing [name] on your computer."
msgstr "Инсталаторът е готов да инсталира [name] във Вашия компютър."

msgctxt "[Messages]ReadyLabel2a"
msgid ""
"Click Install to continue with the installation, or click Back if you want "
"to review or change any settings."
msgstr ""
"Натиснете \"Инсталиране\", за да продължите, или \"Назад\" за преглед или "
"промяна на някои настройки."

msgctxt "[Messages]ReadyLabel2b"
msgid "Click Install to continue with the installation."
msgstr "Натиснете \"Инсталиране\", за да продължите с инсталирането."

