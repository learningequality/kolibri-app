msgid ""
"A newer version of {#AppName} (%1) is already installed. This installer "
"contains version %2, which is older. The setup will now exit."
msgstr ""

msgctxt "[CustomMessages]sameversioninstalled"
msgid ""
"This version of %1 is already installed. Do you want to repair the "
"installation by reinstalling it?"
msgstr ""

