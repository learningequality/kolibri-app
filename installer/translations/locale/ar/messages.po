msgid ""
"An older version of {#AppName} (%1) was detected. Do you want to upgrade to "
"version {#AppVersion}?"
msgstr ""

msgctxt "[CustomMessages]confirmuninstalldata"
msgid ""
"Do you want to completely remove all Kolibri user data? This includes all "
"downloaded content, user accounts, and progress, and cannot be undone."
msgstr ""

