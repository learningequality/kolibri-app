msgid ""
"A critical error occurred while trying to run a setup command: %1. The "
"installation cannot continue."
msgstr ""

msgctxt "[CustomMessages]commanderror"
msgid ""
"A command required for setup failed to execute correctly: %1. Error Code: "
"%2. The installation cannot continue."
msgstr ""

msgctxt "[CustomMessages]versionparseerror"
msgid ""
"Could not compare versions due to an invalid version format. Please "
"uninstall the previous version manually and try again."
msgstr ""

msgctxt "[CustomMessages]migrationfailed"
msgid ""
"The installer failed to migrate user data from the old location (%1) to the "
"new location (%2). Your data has not been moved. Please contact support for "
"assistance."
msgstr ""

