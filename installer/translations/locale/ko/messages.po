msgid "Browse For Folder"
msgstr "폴더 찾아보기"

msgctxt "[Messages]BrowseDialogLabel"
msgid "Select a folder in the list below, then click OK."
msgstr "아래 목록에서 폴더를 선택한 후 확인을 클릭하세요."

msgctxt "[Messages]NewFolderName"
msgid "New Folder"
msgstr "새 폴더"

msgctxt "[Messages]WelcomeLabel1"
msgid "Welcome to the [name] Setup Wizard"
msgstr "[name] 설치 마법사에 오신 것을 환영합니다"

msgctxt "[Messages]WelcomeLabel2"
msgid ""
"This will install [name/ver] on your computer.%n%nIt is recommended that you"
" close all other applications before continuing."
msgstr "컴퓨터에 [name/ver]이(가) 설치됩니다.%n%n계속하기 전에 다른 모든 응용 프로그램을 닫는 것이 좋습니다."

msgctxt "[Messages]WizardPassword"
msgid "Password"
msgstr "암호"

msgctxt "[Messages]PasswordLabel1"
msgid "This installation is password protected."
msgstr "이 설치는 암호로 보호됩니다."

msgctxt "[Messages]PasswordLabel3"
msgid ""
"Please provide the password, then click Next to continue. Passwords are "
"case-sensitive."
msgstr "암호를 입력한 후 다음을 클릭하여 계속하세요. 암호는 대소문자를 구분합니다."

msgctxt "[Messages]PasswordEditLabel"
msgid "&Password:"
msgstr "암호(&P):"

msgctxt "[Messages]IncorrectPassword"
msgid "The password you entered is not correct. Please try again."
msgstr "입력한 암호가 올바르지 않습니다. 다시 시도하세요."

msgctxt "[Messages]WizardLicense"
msgid "License Agreement"
msgstr "라이선스 계약"

msgctxt "[Messages]LicenseLabel"
msgid "Please read the following important information before continuing."
msgstr "계속하기 전에 다음 중요한 정보를 읽어보세요."

msgctxt "[Messages]LicenseLabel3"
msgid ""
"Please read the following License Agreement. You must accept the terms of "
"this agreement before continuing with the installation."
msgstr "다음 라이선스 계약을 읽어보세요. 설치를 계속하기 전에 이 계약 조건에 동의해야 합니다."

msgctxt "[Messages]LicenseAccepted"
msgid "I &accept the agreement"
msgstr "동의합니다(&A)"

msgctxt "[Messages]LicenseNotAccepted"
msgid "I &do not accept the agreement"
msgstr "동의하지 않습니다(&D)"

msgctxt "[Messages]WizardInfoBefore"
msgid "Information"
msgstr "정보"

msgctxt "[Messages]InfoBeforeLabel"
msgid "Please read the following important information before continuing."
msgstr "계속하기 전에 다음 중요한 정보를 읽어보세요."

msgctxt "[Messages]InfoBeforeClickLabel"
msgid "When you are ready to continue with Setup, click Next."
msgstr "설치를 계속할 준비가 되었으면 다음을 클릭합니다."

msgctxt "[Messages]WizardInfoAfter"
msgid "Information"
msgstr "정보"

msgctxt "[Messages]InfoAfterLabel"
msgid "Please read the following important information before continuing."
msgstr "계속하기 전에 다음 중요한 정보를 읽어보세요."

msgctxt "[Messages]InfoAfterClickLabel"
msgid "When you are ready to continue with Setup, click Next."
msgstr "설치를 계속할 준비가 되었으면 다음을 클릭합니다."

msgctxt "[Messages]WizardUserInfo"
msgid "User Information"
msgstr "사용자 정보"

msgctxt "[Messages]UserInfoDesc"
msgid "Please enter your information."
msgstr "사용자 정보를 입력하세요."

msgctxt "[Messages]UserInfoName"
msgid "&User Name:"
msgstr "사용자 이름(&U):"

msgctxt "[Messages]UserInfoOrg"
msgid "&Organization:"
msgstr "조직(&O):"

msgctxt "[Messages]UserInfoSerial"
msgid "&Serial Number:"
msgstr "일련 번호:(&S):"

msgctxt "[Messages]UserInfoNameRequired"
msgid "You must enter a name."
msgstr "이름을 입력해야 합니다."

msgctxt "[Messages]WizardSelectDir"
msgid "Select Destination Location"
msgstr "대상 위치 선택"

msgctxt "[Messages]SelectDirDesc"
msgid "Where should [name] be installed?"
msgstr "[name]을(를) 어디에 설치하시겠습니까?"

msgctxt "[Messages]SelectDirLabel3"
msgid "Setup will install [name] into the following folder."
msgstr "다음 폴더에 [name]을(를) 설치합니다."

msgctxt "[Messages]SelectDirBrowseLabel"
msgid ""
"To continue, click Next. If you would like to select a different folder, "
"click Browse."
msgstr "계속하려면 다음을 클릭합니다. 다른 폴더를 선택하려면 찾아보기를 클릭합니다."

msgctxt "[Messages]DiskSpaceGBLabel"
msgid "At least [gb] GB of free disk space is required."
msgstr "이 프로그램은 최소 [gb] GB의 디스크 여유 공간이 필요합니다."

msgctxt "[Messages]DiskSpaceMBLabel"
msgid "At least [mb] MB of free disk space is required."
msgstr "이 프로그램은 최소 [mb] MB의 디스크 여유 공간이 필요합니다."

msgctxt "[Messages]CannotInstallToNetworkDrive"
msgid "Setup cannot install to a network drive."
msgstr "네트워크 드라이브에 설치할 수 없습니다."

msgctxt "[Messages]CannotInstallToUNCPath"
msgid "Setup cannot install to a UNC path."
msgstr "UNC 경로에 설치할 수 없습니다."

msgctxt "[Messages]InvalidPath"
msgid ""
"You must enter a full path with drive letter; for example:%n%nC:\\APP%n%nor "
"a UNC path in the form:%n%n\\\\server\\share"
msgstr ""
"드라이브 문자를 포함한 전체 경로를 입력해야 합니다. 예:%n%nC:\\APP%n%n 또는 UNC 경로 "
"형식:%n%n\\\\server\\share"

msgctxt "[Messages]InvalidDrive"
msgid ""
"The drive or UNC share you selected does not exist or is not accessible. "
"Please select another."
msgstr "선택한 드라이브 또는 UNC 공유가 존재하지 않거나 액세스할 수 없습니다, 다른 경로를 선택하세요."

msgctxt "[Messages]DiskSpaceWarningTitle"
msgid "Not Enough Disk Space"
msgstr "디스크 공간이 부족합니다"

msgctxt "[Messages]DiskSpaceWarning"
msgid ""
"Setup requires at least %1 KB of free space to install, but the selected "
"drive only has %2 KB available.%n%nDo you want to continue anyway?"
msgstr ""
"설치 시 최소 %1 KB 디스크 공간이 필요하지만, 선택한 드라이브의 여유 공간은 %2 KB 밖에 없습니다.%n%n그래도 "
"계속하시겠습니까?"

msgctxt "[Messages]DirNameTooLong"
msgid "The folder name or path is too long."
msgstr "폴더 이름 또는 경로가 너무 깁니다."

msgctxt "[Messages]InvalidDirName"
msgid "The folder name is not valid."
msgstr "폴더 이름이 유효하지 않습니다."

msgctxt "[Messages]BadDirName32"
msgid "Folder names cannot include any of the following characters:%n%n%1"
msgstr "폴더 이름은 다음 문자를 포함할 수 없습니다:%n%n%1"

msgctxt "[Messages]DirExistsTitle"
msgid "Folder Exists"
msgstr "폴더가 존재합니다"

msgctxt "[Messages]DirExists"
msgid ""
"The folder:%n%n%1%n%nalready exists. Would you like to install to that "
"folder anyway?"
msgstr "폴더 %n%n%1%n%n이(가) 이미 존재합니다, 그래도 해당 폴더에 설치하시겠습니까?"

msgctxt "[Messages]DirDoesntExistTitle"
msgid "Folder Does Not Exist"
msgstr "폴더가 존재하지 않습니다"

msgctxt "[Messages]DirDoesntExist"
msgid ""
"The folder:%n%n%1%n%ndoes not exist. Would you like the folder to be "
"created?"
msgstr "폴더 %n%n%1%n%n이(가) 존재하지 않습니다, 폴더를 만드시겠습니까?"

msgctxt "[Messages]WizardSelectComponents"
msgid "Select Components"
msgstr "구성 요소 선택"

msgctxt "[Messages]SelectComponentsDesc"
msgid "Which components should be installed?"
msgstr "어떤 구성 요소를 설치하시겠습니까?"

msgctxt "[Messages]SelectComponentsLabel2"
msgid ""
"Select the components you want to install; clear the components you do not "
"want to install. Click Next when you are ready to continue."
msgstr "설치하려는 구성 요소를 선택합니다; 설치하지 않으려는 구성 요소의 선택을 취소합니다. 계속할 준비가 되면 다음을 클릭합니다."

msgctxt "[Messages]FullInstallation"
msgid "Full installation"
msgstr "전체 설치"

msgctxt "[Messages]CompactInstallation"
msgid "Compact installation"
msgstr "최소 설치"

msgctxt "[Messages]CustomInstallation"
msgid "Custom installation"
msgstr "사용자 지정 설치"

msgctxt "[Messages]NoUninstallWarningTitle"
msgid "Components Exist"
msgstr "구성 요소가 존재합니다"

msgctxt "[Messages]NoUninstallWarning"
msgid ""
"Setup has detected that the following components are already installed on "
"your computer:%n%n%1%n%nDeselecting these components will not uninstall "
"them.%n%nWould you like to continue anyway?"
msgstr ""
"다음 구성 요소가 컴퓨터에 이미 설치되어 있습니다: %n%n%1%n%n이러한 구성 요소를 선택해도 제거되지 "
"않습니다.%n%n계속하시겠습니까?"

msgctxt "[Messages]ComponentSize1"
msgid "%1 KB"
msgstr "%1 KB"

msgctxt "[Messages]ComponentSize2"
msgid "%1 MB"
msgstr "%1 MB"

msgctxt "[Messages]ComponentsDiskSpaceGBLabel"
msgid "Current selection requires at least [gb] GB of disk space."
msgstr "현재 선택은 최소 [gb] GB의 디스크 여유 공간이 필요합니다."

msgctxt "[Messages]ComponentsDiskSpaceMBLabel"
msgid "Current selection requires at least [mb] MB of disk space."
msgstr "현재 선택은 최소 [mb] MB의 디스크 여유 공간이 필요합니다."

msgctxt "[Messages]WizardSelectTasks"
msgid "Select Additional Tasks"
msgstr "추가 작업 선택"

msgctxt "[Messages]SelectTasksDesc"
msgid "Which additional tasks should be performed?"
