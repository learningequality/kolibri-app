msgstr "압축파일을 추출하는 동안 오류 발생:"

msgctxt "[Messages]ErrorReplacingExistingFile"
msgid "An error occurred while trying to replace the existing file:"
msgstr "기존 파일을 교체하는 동안 오류 발생:"

msgctxt "[Messages]ErrorRestartReplace"
msgid "RestartReplace failed:"
msgstr "RestartReplace 실패:"

msgctxt "[Messages]ErrorRenamingTemp"
msgid ""
"An error occurred while trying to rename a file in the destination "
"directory:"
msgstr "대상 디렉터리 내의 파일 이름을 바꾸는 동안 오류 발생:"

msgctxt "[Messages]ErrorRegisterServer"
msgid "Unable to register the DLL/OCX: %1"
msgstr "DLL/OCX를 등록할 수 없습니다: %1"

msgctxt "[Messages]ErrorRegSvr32Failed"
msgid "RegSvr32 failed with exit code %1"
msgstr "종료 코드 %1로 인해 RegSvr32가 실패했습니다"

msgctxt "[Messages]ErrorRegisterTypeLib"
msgid "Unable to register the type library: %1"
msgstr "유형 라이브러리를 등록할 수 없습니다: %1"

msgctxt "[Messages]UninstallDisplayNameMark"
msgid "%1 (%2)"
msgstr "%1 (%2)"

msgctxt "[Messages]UninstallDisplayNameMarks"
msgid "%1 (%2, %3)"
msgstr "%1 (%2, %3)"

msgctxt "[Messages]UninstallDisplayNameMark32Bit"
msgid "32-bit"
msgstr "32비트"

msgctxt "[Messages]UninstallDisplayNameMark64Bit"
msgid "64-bit"
msgstr "64비트"

msgctxt "[Messages]UninstallDisplayNameMarkAllUsers"
msgid "All users"
msgstr "모든 사용자"

msgctxt "[Messages]UninstallDisplayNameMarkCurrentUser"
msgid "Current user"
msgstr "현재 사용자"

msgctxt "[Messages]ErrorOpeningReadme"
msgid "An error occurred while trying to open the README file."
msgstr "README 파일을 여는 동안 오류가 발생했습니다."

msgctxt "[Messages]ErrorRestartingComputer"
msgid "Setup was unable to restart the computer. Please do this manually."
msgstr "컴퓨터를 다시 시작하지 못했습니다. 이 작업을 수동으로 수행하세요."

msgctxt "[Messages]UninstallNotFound"
msgid "File \"%1\" does not exist. Cannot uninstall."
msgstr "\"%1\" 파일이 없습니다. 제거할 수 없습니다."

msgctxt "[Messages]UninstallOpenError"
msgid "File \"%1\" could not be opened. Cannot uninstall"
msgstr "\"%1\" 파일을 열 수 없습니다. 제거할 수 없습니다"

msgctxt "[Messages]UninstallUnsupportedVer"
msgid ""
"The uninstall log file \"%1\" is in a format not recognized by this version "
"of the uninstaller. Cannot uninstall"
msgstr "\"%1\" 제거 로그 파일이 현재 버전의 제거 프로그램에서 인식할 수 없는 형식입니다. 제거할 수 없습니다"

msgctxt "[Messages]UninstallUnknownEntry"
msgid "An unknown entry (%1) was encountered in the uninstall log"
msgstr "제거 로그에 알 수 없는 항목 (%1)이 있습니다"

msgctxt "[Messages]ConfirmUninstall"
msgid ""
"Are you sure you want to completely remove %1 and all of its components?"
msgstr "%1 및 해당 구성 요소를 모두 제거하시겠습니까?"

msgctxt "[Messages]UninstallOnlyOnWin64"
msgid "This installation can only be uninstalled on 64-bit Windows."
msgstr "이 설치는 64비트 Windows에서만 제거할 수 있습니다."

msgctxt "[Messages]OnlyAdminCanUninstall"
msgid ""
"This installation can only be uninstalled by a user with administrative "
"privileges."
msgstr "이 설치는 관리자 권한이 있는 사용자만 제거할 수 있습니다."

msgctxt "[Messages]UninstallStatusLabel"
msgid "Please wait while %1 is removed from your computer."
msgstr "%1이(가) 컴퓨터에서 제거되는 동안 기다려 주세요."

msgctxt "[Messages]UninstalledAll"
msgid "%1 was successfully removed from your computer."
msgstr "%1이(가) 컴퓨터에서 성공적으로 제거되었습니다."

msgctxt "[Messages]UninstalledMost"
msgid ""
"%1 uninstall complete.%n%nSome elements could not be removed. These can be "
"removed manually."
msgstr "%1 제거가 완료되었습니다.%n%n일부 요소를 제거할 수 없습니다. 수동으로 제거할 수 있습니다."

msgctxt "[Messages]UninstalledAndNeedsRestart"
msgid ""
"To complete the uninstallation of %1, your computer must be "
"restarted.%n%nWould you like to restart now?"
msgstr "%1 제거를 완료하려면 컴퓨터를 다시 시작해야 합니다.%n%n지금 다시 시작하시겠습니까?"

msgctxt "[Messages]UninstallDataCorrupted"
msgid "\"%1\" file is corrupted. Cannot uninstall"
msgstr "\"%1\" 파일이 손상되었습니다. 제거할 수 없습니다."

msgctxt "[Messages]ConfirmDeleteSharedFileTitle"
msgid "Remove Shared File?"
msgstr "공유 파일을 제거하시겠습니까?"

msgctxt "[Messages]ConfirmDeleteSharedFile2"
msgid ""
"The system indicates that the following shared file is no longer in use by "
"any programs. Would you like for Uninstall to remove this shared file?%n%nIf"
" any programs are still using this file and it is removed, those programs "
"may not function properly. If you are unsure, choose No. Leaving the file on"
" your system will not cause any harm."
msgstr ""
"시스템에 다음 공유 파일이 더 이상 어떤 프로그램에서도 사용되지 않는 것으로 표시됩니다. 제거에서 이 공유 파일을 "
"제거하시겠습니까?%n%n이 파일을 계속 사용하고 있고 파일이 제거된 프로그램이 있으면 해당 프로그램이 제대로 작동하지 않을 수 있습니다."
" 확실하지 않은 경우 아니요를 선택합니다. 파일을 시스템에 남겨두어도 아무런 해가 되지 않습니다."

